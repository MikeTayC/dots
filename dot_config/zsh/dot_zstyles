# https://github.com/aloxaf/fzf-tab?tab=readme-ov-file#configure

# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# set descriptions format to enable group support
# NOTE: don't use escape sequences (like '%F{red}%d%f') here, fzf-tab will ignore them
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'
zstyle ':completion:*' group-name ''
# set list-colors to enable filename colorizing
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# force zsh not to show completion menu, which allows fzf-tab to capture the unambiguous prefix
zstyle ':completion:*' menu no

# show .dotfiles 
zstyle ':completion:*' matcher-list '' 'm:{a-z}={A-Z}'
# Only for `cd`
zstyle ':completion:*:*:cd:*:*' tag-order 'local-directories directory-stack path-directories'
# Optional: explicitly set default for everything else
zstyle ':completion:*' list-dirs-first false

zstyle ':completion:*' special-dirs true
zstyle ':completion:*:*:(cat|bat|ccat|vim|nvim|less):*:*' file-patterns '.* *'

# disbable the possiblity prompts like "do you wish to see all 165 possibilities"
zstyle ':completion:*' list-prompt   ''
zstyle ':completion:*' select-prompt ''

# preview directory's content with eza when completing cd
#zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# custom fzf flags
# NOTE: fzf-tab does not follow FZF_DEFAULT_OPTS by default
zstyle ':fzf-tab:*' fzf-flags --color=fg:1,fg+:2 --bind=tab:accept --style=minimal --height=50% --min-height=20 --preview-window=right:60%:wrap:border
# To make fzf-tab follow FZF_DEFAULT_OPTS.
# NOTE: This may lead to unexpected behavior since some flags break this plugin. See Aloxaf/fzf-tab#455.
zstyle ':fzf-tab:*' use-fzf-default-opts yes
# switch group using `<` and `>`
zstyle ':fzf-tab:*' switch-group '<' '>'

## Customizationls
zstyle ':fzf-tab:complete:export:*' fzf-preview 'echo ${(P)word}'
zstyle ':fzf-tab:complete:unset:*' fzf-preview 'echo ${(P)word}'
zstyle ':fzf-tab:complete:ssh:*' fzf-preview 'dig $word'
zstyle ':fzf-tab:complete:(cd|eza|ll|ls|la|l|t|tree|vim|vi|cat|bat|ccat):*' fzf-flags '--preview-window=right:70%:'
zstyle ':fzf-tab:complete:*' fzf-preview '
if [[ -n "$desc" ]]; then
    echo "word: $word -- description: $desc"
elif [[ -z $realpath ]]; then
  echo $word
elif [[ -d $realpath ]]; then
  script -q /dev/null eza --tree --level=2 $eza_params $realpath | head -200
else
  bat -n --color=always $realpath 2>/dev/null || cat $realpath
fi
'

# fzf replace up arrow history
bindkey '^[[A' fzf-history-widget
bindkey "${terminfo[kcuu1]}" fzf-history-widget


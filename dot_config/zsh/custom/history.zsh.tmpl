# history range - usage: history -E -l $1 $2
alias hsr='history -E -l'
alias hsg='history | grep'

# increase SAVEHIST to 50000 - This controls the number of entries from HISTFILE into zsh shell memory
[ "$SAVEHIST" -lt 50000 ] && SAVEHIST=50000

setopt HIST_REDUCE_BLANKS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_SAVE_NO_DUPS
setopt HIST_FIND_NO_DUPS

{{- if (index (default dict .tools) "drunk_zsh_history") }}
ZSH_HISTORY_FILE=$HISTFILE
ZSH_HISTORY_PROJ="$XDG_CONFIG_HOME/drunk_zsh_history"
ZSH_HISTORY_FILE_ENC="$ZSH_HISTORY_PROJ/zsh_history"
GIT_COMMIT_MSG="latest $(date)"
{{- end }}

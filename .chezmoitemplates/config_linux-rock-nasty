[data.zsh]
    ZSH = ".antidote"
    ZSH_SRC = "git@github.com:mattmc3/antidote.git"
    ZSH_PLUGIN_MGR = 'antidote'
    ZSH_CUSTOM = ".config/zsh/custom"
    ZSH_THEME = 'starship'
    ANTI_PLUGINS = [
      "mattmc3/ez-compinit",
      "zsh-users/zsh-completions kind:fpath path:src",
      "aloxaf/fzf-tab",
      "mattmc3/zephyr path:plugins/history",
      "mattmc3/zephyr path:plugins/utility",
      "mattmc3/zephyr path:plugins/directory",
      "z-shell/zsh-eza kind:defer",
      "zdharma-continuum/fast-syntax-highlighting kind:defer",
      "zsh-users/zsh-autosuggestions kind:defer"
    ]   

[data.tools]
    brew = false
    mise = false
    chezmoi = true
    npm = false
    pnpm = false
    vim_runtime = true
    eza = true
    fzf = true
    bat = true
    zsh-autosuggestions = true
    drunk_zsh_history = false
    aws = false
    helm = false
    terragrunt = false
    terraform = false
    cafe_countdown = false
    iterm = false

